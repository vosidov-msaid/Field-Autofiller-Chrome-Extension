{
  "manifest_version": 3,
  "name": "Field Autofiller",
  "description": "Autofill common fields like name, email, phone, and address. Also supports custom field hints for more accurate autofilling.",
  "version": "1.0.0",
  "action": {
    "default_title": "Field Autofiller"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
